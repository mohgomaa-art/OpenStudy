{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenStudy",
  "version": "0.1.0",
  "identifier": "com.openstudy.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite -- --port 5173",
    "beforeBuildCommand": "npm run build:vite"
  },

  "app": {
    "windows": [
      {
        "title": "OpenStudy",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "OpenStudyBackend.exe"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
